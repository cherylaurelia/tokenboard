# tokenboard — environment template. Copy to `.env` and fill in.
# `.env` is gitignored; never commit real secrets. (IMPLEMENTATION.md §4)

# ── Supabase (Postgres + Auth) ────────────────────────────────────────────
# Project dashboard → Settings → Database / API.
# DATABASE_URL  = Supavisor *pooler* URI for the app (port 6543, transaction mode).
#                 Drizzle uses postgres-js with prepare:false against this.
# DIRECT_URL    = direct connection (port 5432) — used for migrations only.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?prepare=false
DIRECT_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Web runtime (browser-exposed). @supabase/ssr's browser+server clients read these;
# they mirror SUPABASE_URL / SUPABASE_ANON_KEY. The publishable key is browser-safe by
# design. NEVER give the SERVICE_ROLE/secret key a NEXT_PUBLIC_ prefix. For `next dev`,
# also copy these into web/.env.local (gitignored), or run `dotenv -e ../.env -- next dev`.
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── GitHub OAuth (web auth, via Supabase) ─────────────────────────────────
# Create a GitHub OAuth App. Authorization callback URL MUST be:
#   https://<ref>.supabase.co/auth/v1/callback
# Then paste Client ID + Secret into Supabase dashboard → Authentication →
# Providers → GitHub. The secret lives in Supabase, NOT in this app.
# (Kept here only for reference / local docs.)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ── Upstash Redis (leaderboard ZSETs, rate limits, idempotency) ───────────
# console.upstash.com → Redis database → REST API section.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Upstash QStash (nightly sweep, signed POST to a Next route) ────────────
# console.upstash.com → QStash → Request Builder / Keys. QSTASH_URL is the regional
# API base (e.g. https://qstash-us-east-1.upstash.io).
QSTASH_URL=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
# Public https origin of this deploy (e.g. https://tokenboard.sh). The QStash-signed sweep
# route reconstructs the signed destination URL from this (NOT request.url, which differs
# behind a proxy). For local dev: http://localhost:3000.
SWEEP_PUBLIC_URL=

# ── Resend (work-email magic-link / OTP) ──────────────────────────────────
RESEND_API_KEY=

# ── App secrets (generated locally — `openssl rand`) ──────────────────────
# APP_ENCRYPTION_KEY encrypts linked_accounts.access_token (32-byte base64).
# HASH_PEPPER salts machine/email hashes (32-byte hex).
APP_ENCRYPTION_KEY=
HASH_PEPPER=

# ── Price table pin (vendored LiteLLM snapshot) ───────────────────────────
# Commit SHA of the LiteLLM price table we vendor — never hot-link main.
PRICE_TABLE_SHA=

# ── CLI dev override (not a secret) ───────────────────────────────────────
# Point `tokenboard claim`/`sync` at a local web server. Default is prod
# https://tokenboard.sh. Set for local dev, e.g. http://localhost:3000.
TOKENBOARD_API_URL=
