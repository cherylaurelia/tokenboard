# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build output
dist/
build/
out/
.next/
.turbo/
.vercel/
*.tsbuildinfo
next-env.d.ts

# Rust (if/when a native parser crate is added later)
target/
**/*.rs.bk
Cargo.lock

# Env / secrets — never commit
.env
.env.*
!.env.example
*.local

# Internal design docs — kept out of the repo (proprietary product/engineering
# design). They live on disk only; if the repo goes public these must NOT ship.
# NOTE: untracking does not purge git history — these were tracked through
# commit 1dbc043, so a history rewrite is still needed to fully erase them.
/DESIGN.md
/ARCHITECTURE.md
/IMPLEMENTATION.md

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test / coverage
coverage/
.nyc_output/

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/*
!.vscode/extensions.json

# tokenboard local CLI state (must never be committed)
.config/tokenboard/
*.tokenboard-auth.json

# Prototype screenshots are tracked on purpose (they're design artifacts);
# scratch shots are not
prototypes/shots/*.tmp.png
.vercel

# Playwright MCP scratch output (browser-probe snapshots/screenshots/logs)
.playwright-mcp/
