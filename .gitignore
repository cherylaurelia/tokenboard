# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build output
dist/
build/
out/
.next/
.turbo/
.vercel/
*.tsbuildinfo
next-env.d.ts

# Rust (if/when a native parser crate is added later)
target/
**/*.rs.bk
Cargo.lock

# Env / secrets — never commit
.env
.env.*
!.env.example
*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test / coverage
coverage/
.nyc_output/

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/*
!.vscode/extensions.json

# tokenboard local CLI state (must never be committed)
.config/tokenboard/
*.tokenboard-auth.json

# Prototype screenshots are tracked on purpose (they're design artifacts);
# scratch shots are not
prototypes/shots/*.tmp.png
.vercel
