{
  "name": "tokenboard-monorepo",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "pnpm -r build",
    "build:cli": "pnpm --filter @tokenboard/cli build",
    "build:web": "pnpm --filter web build",
    "dev:web": "pnpm --filter web dev",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter web exec drizzle-kit generate --custom",
    "db:migrate": "pnpm --filter web exec dotenv -e ../.env -- drizzle-kit migrate"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "tsup": "8.5.1",
    "dotenv-cli": "10.0.0"
  }
}
