{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],
    "paths": { "@/*": ["./src/*"] },
    "allowJs": true,
    "incremental": true
  },
  "include": ["next-env.d.ts", "src", ".next/types/**/*.ts", "drizzle.config.ts", "middleware.ts", "next.config.ts"],
  "exclude": ["node_modules"]
}
